+// ExecInteractive is a fermata addition: like Exec, but attaches the given stdin
+// and writes container output to stdout, with a TTY, so the command (e.g. a
+// shell) is interactive. The caller owns terminal raw-mode setup and must pass
+// the sole reader of the real stdin to avoid byte-stealing.
+func (cr *containerReference) ExecInteractive(command []string, env map[string]string, user, workdir string, stdin io.Reader, stdout io.Writer) common.Executor {
+	return common.NewPipelineExecutor(
+		cr.connect(),
+		cr.find(),
+		cr.execInteractive(command, env, user, workdir, stdin, stdout),
+	).IfNot(common.Dryrun)
+}
+
+func (cr *containerReference) execInteractive(cmd []string, env map[string]string, user, workdir string, stdin io.Reader, stdout io.Writer) common.Executor {
+	return func(ctx context.Context) error {
+		if stdout == nil {
+			stdout = os.Stdout
+		}
+		envList := make([]string, 0, len(env))
+		for k, v := range env {
+			envList = append(envList, fmt.Sprintf("%s=%s", k, v))
+		}
+
+		wd := cr.input.WorkingDir
+		if workdir != "" {
+			if strings.HasPrefix(workdir, "/") {
+				wd = workdir
+			} else {
+				wd = fmt.Sprintf("%s/%s", cr.input.WorkingDir, workdir)
+			}
+		}
+
+		idResp, err := cr.cli.ExecCreate(ctx, cr.id, client.ExecCreateOptions{
+			User:         user,
+			Cmd:          cmd,
+			WorkingDir:   wd,
+			Env:          envList,
+			TTY:          true,
+			AttachStdin:  stdin != nil,
+			AttachStderr: true,
+			AttachStdout: true,
+		})
+		if err != nil {
+			return fmt.Errorf("failed to create interactive exec: %w", err)
+		}
+
+		resp, err := cr.cli.ExecAttach(ctx, idResp.ID, client.ExecAttachOptions{TTY: true})
+		if err != nil {
+			return fmt.Errorf("failed to attach to interactive exec: %w", err)
+		}
+		defer resp.Close()
+
+		if stdin != nil {
+			go func() {
+				_, _ = io.Copy(resp.Conn, stdin)
+				_ = resp.CloseWrite()
+			}()
+		}
+
+		// With a TTY, output is a single multiplexed stream — copy directly.
+		_, err = io.Copy(stdout, resp.Reader)
+		return err
+	}
+}
